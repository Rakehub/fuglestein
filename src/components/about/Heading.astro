---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-4 sm:gap-6">
      <h1 class="text-5xl font-light tracking-tight sm:text-6xl lg:text-7xl text-primary-950 dark:text-white" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        {title}
      </h1>
      
      <p class="text-primary-900/80 dark:text-primary-200/80 mx-auto max-w-xl text-xl sm:text-2xl italic font-light leading-relaxed" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        {subtitle}
      </p>
    </div>
  </div>
</section>