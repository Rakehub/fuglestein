---
interface Props {
  videoSrc: string;
  description: string;
}

const { videoSrc, description } = Astro.props;
---

<section class="relative w-full overflow-hidden">
  <div class="relative w-full h-[60vh] sm:h-screen lg:h-[750px] lg:max-w-7xl lg:mx-auto lg:my-10 lg:rounded-3xl lg:shadow-2xl overflow-hidden">
    <video 
      autoplay 
      muted 
      loop 
      playsinline 
      poster="/images/vid.jpg"
      class="absolute inset-0 w-full h-full object-cover object-center" 
    >
      <source src={videoSrc} type="video/mp4" />
    </video>

<script>
  // Forzar reproducción al cargar la página
  const video = document.getElementById('myVideo');
  const playVideo = () => {
    video.play().catch(error => {
      console.log("Autoplay bloqueado, el usuario necesita interactuar.");
    });
  };
  
  // Ejecutar cuando el navegador esté listo
  window.addEventListener('load', playVideo);
  // También ejecutar si el usuario toca cualquier parte de la pantalla
  window.addEventListener('touchstart', playVideo, { once: true });
</script>

    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent pointer-events-none"></div>
  </div>

  <p class="text-center text-primary-900/60 dark:text-primary-200/60 font-light tracking-wide text-xl sm:text-2xl mt-12 max-w-2xl mx-auto italic leading-relaxed" style="font-family: 'Cormorant Garamond', Georgia, serif;">
    {description}
  </p>
</section>
