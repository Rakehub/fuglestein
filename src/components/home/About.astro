---
const services = [
  {
    name: 'Fjord Norway',
    description: 'Gardsbutikken vår er vakkert plassert ved fjorden i Suldal. På den offisielle reiselivsportalen for Vestlandet blir me trekte fram som eit flott stoppested for å smaka og kjøpa lokal eplemost og sider.',
    image: '/assets/fjord.webp',
    link: 'https://www.fjordnorway.com/en/see-and-do/farm-shop-at-fuglestein-fruktgard-in-suldal',
    alt: 'Fuglestein Fruktgard presentert på den offisielle reiselivssida Fjord Norway'
  },
  {
    name: 'Visit Norway',
    description: 'Fruktdyrkinga på Fuglestein strekkjer seg heilt tilbake til 1838 i eit historisk område i Jelsa. Med 17 000 nye frukttre produserer me sider, eplemost og eplegele, som blir trekt fram på den offisielle reiselivsportalen.',
    image: '/assets/press.webp',
    link: 'https://www.visitnorway.com/listings/farm-shop-at-fuglestein-fruktgard-in-suldal/243969/',
    alt: 'Gardsbutikken til Fuglestein Fruktgard omtalt på Visit Norway'
  },
  {
    name: 'Visit Suldal',
    description: 'Som ein del av "Matskattar frå Suldal" ligg garden vår idyllisk til ved Økstrafjorden. På den lokale turistguiden blir me trekt fram for gardsbesøk, omvising i eplehagen og smaksprøvar av lokalproduserte varer.',
    image: '/assets/suldal.webp',
    link: 'https://www.visitsuldal.com/eat-and-stay/fuglestein-fruktgard-fuglestein',
    alt: 'Fuglestein Fruktgard som ein del av Matskattar frå Suldal hos Visit Suldal'
  },
];
---
<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-16">
      
      <h2 class="text-4xl font-light tracking-tight sm:text-5xl" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        Ein del av den lokale reisa
      </h2>
      
      <div class="grid gap-12 lg:grid-cols-3">
        {
          services.map((service) => (
            <a 
              href={service.link}
              target="_blank" 
              rel="noopener noreferrer"
              class="group block flex flex-col gap-6"
            >
              <div class="relative w-full aspect-[4/3] overflow-hidden rounded-3xl bg-neutral-100">
                <img 
                  src={service.image} 
                  alt={service.alt} 
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
              </div>

              <div class="flex flex-col gap-3">
                <h3 class="text-2xl font-light text-primary-950 dark:text-primary-50" style="font-family: 'Cormorant Garamond', Georgia, serif;">
                  {service.name}
                </h3>
                <p class="text-lg italic text-primary-900/70 dark:text-primary-200/70 leading-relaxed font-light" style="font-family: 'Cormorant Garamond', Georgia, serif;">
                  {service.description}
                </p>
                
                <div class="mt-2 flex items-center text-[10px] font-medium tracking-[0.2em] uppercase text-primary-500 transition-colors group-hover:text-primary-900 dark:group-hover:text-white">
                  Les meir på nett →
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>