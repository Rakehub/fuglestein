---
// src/components/About.astro
interface Service {
  name: string;
  description: string;
  image: string;
  link: string;
  alt: string;
}

interface Props {
  title: string;
  moreText: string;
  services: Service[];
}

const { title, moreText, services } = Astro.props;
---

<section class="py-16 sm:py-20">
  <div class="mx-auto reveal max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-16">
      
      <h2 class="text-4xl font-light tracking-tight sm:text-5xl" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        {title}
      </h2>
      
      <div class="grid reveal gap-12 lg:grid-cols-3">
        {
          services.map((service) => (
            <a 
              href={service.link}
              target="_blank" 
              rel="noopener noreferrer"
              class="group block flex flex-col gap-6"
            >
              <div class="relative reveal w-full aspect-[4/3] overflow-hidden rounded-3xl bg-neutral-100">
                <img 
                  src={service.image} 
                  alt={service.alt} 
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
              </div>

              <div class="flex reveal flex-col gap-3">
                <h3 class="text-2xl font-light text-primary-950 dark:text-primary-50" style="font-family: 'Cormorant Garamond', Georgia, serif;">
                  {service.name}
                </h3>
                <p class="text-lg italic text-primary-900/70 dark:text-primary-200/70 leading-relaxed font-light" style="font-family: 'Cormorant Garamond', Georgia, serif;">
                  {service.description}
                </p>
                
                <div class="mt-2 flex reveal items-center text-[10px] font-medium tracking-[0.2em] uppercase text-primary-500 transition-colors group-hover:text-primary-900 dark:group-hover:text-white">
                  {moreText} →
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>