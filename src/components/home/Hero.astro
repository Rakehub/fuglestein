---
interface Props {
  title: string;
  description: string;
  imageAlt: string;
}

const { title, description, imageAlt } = Astro.props;
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-16">

      <div class="flex flex-col items-start gap-8 sm:gap-10">
        <div class="flex max-w-3xl flex-col items-start gap-6 sm:gap-8">

          <h1 class="text-5xl font-light tracking-tight sm:text-6xl lg:text-7xl text-primary-950 dark:text-white leading-[1.1]" style="font-family: 'Cormorant Garamond', Georgia, serif;">
            {title}
          </h1>

          <p class="text-xl sm:text-2xl italic font-light text-primary-900/80 dark:text-primary-200/80 leading-relaxed max-w-2xl" style="font-family: 'Cormorant Garamond', Georgia, serif;">
            {description}
          </p>

        </div>
      </div>

<div class="relative left-1/2 right-1/2 -mx-[50vw] w-screen md:left-auto md:right-auto md:mx-0 md:w-full h-[600px] md:h-[750px] rounded-none md:rounded-3xl overflow-hidden shadow-2xl">
  <source
    media="(max-width: 767px)"
    srcset="/assets/drone.webp"
  />
  <img
    src="/assets/drone.webp"
    alt={imageAlt}
    loading="eager"
    decoding="async"
    class="w-full h-full object-cover scale-[1.01]"
  />
</picture>

<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
</div>

    </div>
  </div>
</section>