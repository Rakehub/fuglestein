---
const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : 'no';

const bottomLinks = [
  {
    header: lang === 'en' ? 'Follow us' : 'Følg oss',
    links: [
      { name: 'Instagram', href: 'https://www.instagram.com/fuglesteinfruktgard/', isExternal: true },
      { name: 'Facebook', href: 'https://www.facebook.com/fuglesteinfruktgard/?locale=nb_NO', isExternal: true },
    ],
  },
  {
    header: lang === 'en' ? 'Menu' : 'Meny',
    links: lang === 'en' 
      ? [
          { name: 'Home', href: '/en', isExternal: false },
          { name: 'About us', href: '/en/about', isExternal: false },
          { name: 'Products', href: '/en/product', isExternal: false },
          { name: 'Experiences', href: '/en/exp', isExternal: false },
          { name: 'Contact', href: '/en/contact', isExternal: false },
        ]
      : [
          { name: 'Heim', href: '/', isExternal: false },
          { name: 'Om oss', href: '/about', isExternal: false },
          { name: 'Produkt', href: '/product', isExternal: false },
          { name: 'Opplevingar', href: '/exp', isExternal: false },
          { name: 'Kontakt', href: '/contact', isExternal: false },
        ],
  },
  {
    header: lang === 'en' ? 'Legal' : 'Juridisk',
    links: [
      { name: lang === 'en' ? 'Privacy Policy' : 'Personvern', href: lang === 'en' ? '/en/privacy' : '/privacy', isExternal: false }
    ],
  },
];
---

<footer class="bg-primary-500/10 dark:bg-primary-400/10 py-16 lg:py-20 transition-colors" aria-labelledby="footer-heading">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col justify-between gap-12 sm:gap-16 lg:flex-row">
      
      <div class="flex max-w-sm flex-col items-start gap-6">
        <div class="flex flex-col gap-1 text-base text-primary-950/70 dark:text-primary-200/70">
          <p class="font-medium text-primary-950 dark:text-white text-lg" style="font-family: 'Cormorant Garamond', serif;">Fuglestein Fruktgard</p>
          <p>Økstrafjordvegen 1178</p>
          <p>4234 Jelsa</p>
          <a href="mailto:fuglesteinfruktgard@gmail.com" class="hover:underline">fuglesteinfruktgard@gmail.com</a>
        </div>
        <p class="text-primary-950/70 dark:text-primary-200/70 text-sm">© 2026 Fuglestein. {lang === 'en' ? 'All rights reserved.' : 'Med enerett.'}</p>
      </div>

      <div class="grid max-w-xl flex-1 grid-cols-1 gap-8 sm:grid-cols-3">
        {bottomLinks.map((group) => (
          <div class="flex flex-col gap-4">
            <p class="text-base font-medium" style="font-family: 'Cormorant Garamond', serif;">{group.header}</p>
            <ul class="flex flex-col gap-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.isExternal ? '_blank' : undefined}
                    rel={link.isExternal ? 'noopener' : undefined}
                    class="hover:underline text-base text-primary-950/70 dark:text-primary-200/70"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</footer>