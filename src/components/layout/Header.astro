---
const links = [
  {
    name: 'Heim',
    href: '/',
  },
  {
    name: 'Om oss',
    href: '/about',
  },
  {
    name: 'Produkt',
    href: '/product',
  },
  {
    name: 'Opplevingar',
    href: '/exp',
  },
  {
    name: 'Kontakt',
    href: '/contact',
  },
];
---

<header
  x-data="{ open: false, activeIndex: null, langOpen: false, currentLang: 'no' }"
  class="relative bg-primary-50 dark:bg-primary-950 transition-colors"
>
  <div
    class="mx-auto flex max-w-2xl items-center justify-between px-4 py-3 sm:px-6 sm:py-4 lg:max-w-7xl lg:px-8"
  >
    <!-- Brand logo -->
    <div class="flex">
      <a
        href="/"
        class="focus-visible:outline-primary-950 dark:group-focus-visible:outline-primary-200 rounded-md focus-visible:outline focus-visible:outline-2"
      >
        <span class="sr-only">Fuglestein</span>
        <img
          class="h-14 w-auto"
          width="65"
          height="40"
          :src="$store.theme.isDark ? '/assets/logo-inverted.svg' : '/assets/logo.svg'"
          alt="Fuglestein"
        />
      </a>
    </div>

    <!-- Desktop Navigation - Ultra minimalista y elegante -->
    <nav class="hidden lg:flex items-center justify-center gap-16">
      {
        links.map((link, index) => (
          <a
            href={link.href}
            @mouseenter={`activeIndex = ${index}`}
            @mouseleave="activeIndex = null"
            class="group relative"
          >
            <!-- Texto elegante -->
            <span class="text-xs tracking-[0.15em] font-light text-primary-900 dark:text-primary-100 uppercase transition-all duration-500"
              :class={`activeIndex === ${index} ? 'opacity-60' : 'opacity-80 hover:opacity-100'`}
            >
              {link.name}
            </span>

            <!-- Línea superior decorativa -->
            <div class="absolute -top-2 left-0 h-px bg-gradient-to-r from-transparent via-amber-600 dark:via-amber-500 to-transparent w-0 group-hover:w-full transition-all duration-700"></div>

            <!-- Punto central -->
            <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-3 w-1 h-1 bg-amber-600 dark:bg-amber-500 rounded-full opacity-0 group-hover:opacity-100 transition-all duration-500"></div>

            <!-- Línea inferior decorativa -->
            <div class="absolute bottom-0 left-0 h-px bg-gradient-to-r from-transparent via-amber-600 dark:via-amber-500 to-transparent w-0 group-hover:w-full transition-all duration-700"></div>
          </a>
        ))
      }
    </nav>

    <!-- Actions -->
    <div class="-mr-2 flex items-center space-x-3 sm:space-x-4">
      <!-- Language Selector -->
      <div class="relative" @click.outside="langOpen = false">
        <button
          type="button"
          class="text-primary-900 dark:text-primary-100 inline-flex h-10 w-10 items-center justify-center rounded-full transition-all duration-300 opacity-60 hover:opacity-100 relative text-xl"
          @click="langOpen = !langOpen"
        >
          <span class="sr-only">Toggle language</span>
          <!-- Bandera Noruega (predeterminada) -->
          <span x-show="currentLang === 'no'" x-transition class="block">🇳🇴</span>
          <!-- Bandera Británica -->
          <span x-show="currentLang === 'en'" x-transition class="block">🇬🇧</span>
        </button>

        <!-- Dropdown de idiomas -->
        <div
          x-show="langOpen"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-2"
          class="absolute top-full right-0 mt-3 w-32 bg-white dark:bg-primary-900 rounded-sm shadow-xl border border-primary-200 dark:border-primary-800 overflow-hidden z-50"
        >
          <a
            href="/no"
            @click="langOpen = false; currentLang = 'no'"
            class="block px-4 py-3 text-xs tracking-[0.1em] font-light text-primary-900 dark:text-primary-100 uppercase hover:bg-primary-50 dark:hover:bg-primary-800 transition-colors duration-300 border-b border-primary-100 dark:border-primary-800"
            :class="currentLang === 'no' ? 'bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400' : ''"
          >
            <span class="flex items-center gap-2">
              <span class="text-lg">🇳🇴</span>
              <span>Norsk</span>
              <span x-show="currentLang === 'no'" class="w-1 h-1 bg-amber-600 dark:bg-amber-500 rounded-full ml-auto"></span>
            </span>
          </a>
          <a
            href="/en"
            @click="langOpen = false; currentLang = 'en'"
            class="block px-4 py-3 text-xs tracking-[0.1em] font-light text-primary-900 dark:text-primary-100 uppercase hover:bg-primary-50 dark:hover:bg-primary-800 transition-colors duration-300"
            :class="currentLang === 'en' ? 'bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400' : ''"
          >
            <span class="flex items-center gap-2">
              <span class="text-lg">🇬🇧</span>
              <span>English</span>
              <span x-show="currentLang === 'en'" class="w-1 h-1 bg-amber-600 dark:bg-amber-500 rounded-full ml-auto"></span>
            </span>
          </a>
        </div>
      </div>

      <!-- Toggle theme mode -->
      <button
        type="button"
        class="text-primary-900 dark:text-primary-100 inline-flex h-10 w-10 items-center justify-center rounded-full transition-all duration-300 opacity-60 hover:opacity-100"
        x-data
        @click="$store.theme.toggle()"
      >
        <span class="sr-only">Toggle theme mode</span>
        <svg
          x-cloak
          class="h-4 w-4"
          :class="{ 'hidden': !($store.theme.isDark) }"
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M12 18C8.68629 18 6 15.3137 6 12C6 8.68629 8.68629 6 12 6C15.3137 6 18 8.68629 18 12C18 15.3137 15.3137 18 12 18ZM12 16C14.2091 16 16 14.2091 16 12C16 9.79086 14.2091 8 12 8C9.79086 8 8 9.79086 8 12C8 14.2091 9.79086 16 12 16ZM11 1H13V4H11V1ZM11 20H13V23H11V20ZM3.51472 4.92893L4.92893 3.51472L7.05025 5.63604L5.63604 7.05025L3.51472 4.92893ZM16.9497 18.364L18.364 16.9497L20.4853 19.0711L19.0711 20.4853L16.9497 18.364ZM19.0711 3.51472L20.4853 4.92893L18.364 7.05025L16.9497 5.63604L19.0711 3.51472ZM5.63604 16.9497L7.05025 18.364L4.92893 20.4853L3.51472 19.0711L5.63604 16.9497ZM23 11V13H20V11H23ZM4 11V13H1V11H4Z"
          ></path>
        </svg>
        <svg
          x-cloak
          class="h-4 w-4"
          :class="{ 'hidden': $store.theme.isDark }"
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M10 6C10 10.4183 13.5817 14 18 14C19.4386 14 20.7885 13.6203 21.9549 12.9556C21.4738 18.0302 17.2005 22 12 22C6.47715 22 2 17.5228 2 12C2 6.79948 5.9698 2.52616 11.0444 2.04507C10.3797 3.21152 10 4.56142 10 6ZM4 12C4 16.4183 7.58172 20 12 20C14.9654 20 17.5757 18.3788 18.9571 15.9546C18.6407 15.9848 18.3214 16 18 16C12.4772 16 8 11.5228 8 6C8 5.67863 8.01524 5.35933 8.04536 5.04293C5.62119 6.42426 4 9.03458 4 12ZM18.1642 2.29104L19 2.5V3.5L18.1642 3.70896C17.4476 3.8881 16.8881 4.4476 16.709 5.16417L16.5 6H15.5L15.291 5.16417C15.1119 4.4476 14.5524 3.8881 13.8358 3.70896L13 3.5V2.5L13.8358 2.29104C14.5524 2.1119 15.1119 1.5524 15.291 0.835829L15.5 0H16.5L16.709 0.835829C16.8881 1.5524 17.4476 2.1119 18.1642 2.29104ZM23.1642 7.29104L24 7.5V8.5L23.1642 8.70896C22.4476 8.8881 21.8881 9.4476 21.709 10.1642L21.5 11H20.5L20.291 10.1642C20.1119 9.4476 19.5524 8.8881 18.8358 8.70896L18 8.5V7.5L18.8358 7.29104C19.5524 7.1119 20.1119 6.5524 20.291 5.83583L20.5 5H21.5L21.709 5.83583C21.8881 6.5524 22.4476 7.1119 23.1642 7.29104Z"
          ></path>
        </svg>
      </button>

      <!-- Toggle menu -->
      <button
        type="button"
        class="text-primary-900 dark:text-primary-100 inline-flex h-10 w-10 items-center justify-center rounded-full transition-all duration-300 opacity-60 hover:opacity-100 lg:hidden"
        @click="open = !open"
        @mousedown="if (open) $event.preventDefault()"
        aria-controls="website-menu"
        aria-expanded="false"
        :aria-expanded="open.toString()"
      >
        <span class="sr-only">Toggle menu</span>
        <svg
          x-cloak
          class="h-5 w-5"
          :class="{ 'hidden': open, 'block': !(open) }"
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M19 8H5V10H19V8ZM19 14H5V16H19V14Z"></path>
        </svg>
        <svg
          x-cloak
          class="h-5 w-5"
          :class="{ 'block': open, 'hidden': !(open) }"
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M12.0007 10.5865L16.9504 5.63672L18.3646 7.05093L13.4149 12.0007L18.3646 16.9504L16.9504 18.3646L12.0007 13.4149L7.05093 18.3646L5.63672 16.9504L10.5865 12.0007L5.63672 7.05093L7.05093 5.63672L12.0007 10.5865Z"
          ></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation - Elegancia pura -->
  <div
    class="lg:hidden"
    id="website-menu"
    x-cloak
    x-show="open"
    x-collapse
    x-collapse.duration.400ms
  >
    <!-- Overlay sutil -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/5 dark:to-black/20 pointer-events-none"></div>

    <!-- Contenido -->
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8 relative z-10">
      <nav class="flex flex-col gap-0 py-8 sm:py-12">
        {
          links.map((link, index) => (
            <a
              href={link.href}
              @click="open = false"
              class="group relative px-0 py-4 border-b border-primary-200 dark:border-primary-800 last:border-b-0 transition-all duration-300"
            >
              <!-- Fondo flotante -->
              <div class="absolute inset-0 bg-gradient-to-r from-amber-600/0 via-amber-600/5 to-amber-600/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

              <!-- Contenido -->
              <div class="relative flex items-center justify-between">
                <span class="text-xs tracking-[0.12em] font-light text-primary-900 dark:text-primary-100 uppercase group-hover:text-amber-600 dark:group-hover:text-amber-500 transition-colors duration-300">
                  {link.name}
                </span>

                <!-- Punto decorativo -->
                <div class="w-1 h-1 rounded-full bg-amber-600 dark:bg-amber-500 opacity-0 group-hover:opacity-100 transition-all duration-300"></div>
              </div>

              <!-- Línea decorativa inferior -->
              <div class="absolute bottom-0 left-0 h-px bg-gradient-to-r from-amber-600/0 to-amber-600/0 group-hover:from-amber-600/100 group-hover:to-amber-600/0 transition-all duration-500 w-full"></div>
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<style>
  @media (prefers-reduced-motion: no-preference) {
    a:hover {
      letter-spacing: 0.2em;
    }
  }
</style>