---
const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : 'no';
const basePath = lang === 'en' ? (pathname.replace(/^\/en/, '') || '/') : pathname;
const noHref = basePath;
const enHref = '/en' + (basePath === '/' ? '' : basePath);

const linksNo = [
  { name: 'Heim', href: '/' },
  { name: 'Om oss', href: '/about' },
  { name: 'Produkt', href: '/product' },
  { name: 'Opplevingar', href: '/exp' },
  { name: 'Kontakt', href: '/contact' },
];

const linksEn = [
  { name: 'Home', href: '/en' },
  { name: 'About us', href: '/en/about' },
  { name: 'Products', href: '/en/product' },
  { name: 'Experiences', href: '/en/exp' },
  { name: 'Contact', href: '/en/contact' },
];

const links = lang === 'en' ? linksEn : linksNo;
---
<header
  x-data={`{ open: false, langOpen: false }`}
  class="relative bg-primary-50 dark:bg-primary-950 transition-colors z-50"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6">
    
    <!-- Logo -->
  <a href={lang === 'en' ? '/en' : '/'} class="flex">
    <img 
      class="h-12 w-auto" 
      src="/assets/logo.svg" 
      :src="$store.theme.isDark ? '/assets/logo-inverted.svg' : '/assets/logo.svg'" 
      alt="Fuglestein"
      width="150" 
      height="48" 
    />
  </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-10">
      {links.map((link) => (
        <a href={link.href} class="text-xs tracking-[0.2em] uppercase opacity-70 hover:opacity-100 transition-all font-light text-primary-900 dark:text-primary-100">
          {link.name}
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-4">
      <!-- Language selector -->
      <div class="relative">
        <button @click="langOpen = !langOpen" class="h-10 w-10 flex items-center justify-center text-2xl hover:scale-110 transition-transform">
          {lang === 'no' ? '🇳🇴' : '🇬🇧'}
        </button>
        <div x-show="langOpen" @click.outside="langOpen = false" class="absolute top-full right-0 mt-3 w-40 bg-white dark:bg-primary-900 shadow-2xl z-50 rounded-lg overflow-hidden py-2">
          <a href={noHref} class="flex items-center gap-3 px-5 py-3 text-sm uppercase hover:bg-primary-100 dark:hover:bg-primary-800">
            <span class="text-2xl">🇳🇴</span> Norsk
          </a>
          <a href={enHref} class="flex items-center gap-3 px-5 py-3 text-sm uppercase hover:bg-primary-100 dark:hover:bg-primary-800">
            <span class="text-2xl">🇬🇧</span> English
          </a>
        </div>
      </div>

      <!-- Theme selector-->
      <button class="h-10 w-10 flex items-center justify-center opacity-60 hover:opacity-100 transition-opacity" @click="$store.theme.toggle()" aria-label="Toggle theme">
        <!-- Sun -->
        <svg x-show="$store.theme.isDark" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 18C8.68629 18 6 15.3137 6 12C6 8.68629 8.68629 6 12 6C15.3137 6 18 8.68629 18 12C18 15.3137 15.3137 18 12 18ZM11 1H13V4H11V1ZM11 20H13V23H11V20ZM3.51472 4.92893L4.92893 3.51472L7.05025 5.63604L5.63604 7.05025L3.51472 4.92893ZM16.9497 18.364L18.364 16.9497L20.4853 19.0711L19.0711 20.4853L16.9497 18.364ZM19.0711 3.51472L20.4853 4.92893L18.364 7.05025L16.9497 5.63604L19.0711 3.51472ZM5.63604 16.9497L7.05025 18.364L4.92893 20.4853L3.51472 19.0711L5.63604 16.9497ZM23 11V13H20V11H23ZM4 11V13H1V11H4Z"/>
        </svg>
        <!-- Moon -->
        <svg x-show="!$store.theme.isDark" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M10 6C10 10.4183 13.5817 14 18 14C19.4386 14 20.7885 13.6203 21.9549 12.9556C21.4738 18.0302 17.2005 22 12 22C6.47715 22 2 17.5228 2 12C2 6.79948 5.9698 2.52616 11.0444 2.04507C10.3797 3.21152 10 4.56142 10 6Z"/>
        </svg>
      </button>

      <!-- Mobile button -->
      <button class="lg:hidden h-10 w-10 flex items-center justify-center " @click="open = !open" aria-label="Toggle menu">
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16m-7 6h7" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div x-show="open" x-collapse class="lg:hidden bg-primary-50 dark:bg-primary-950 px-6 pb-8 flex flex-col items-center gap-6">
    {links.map((link) => (
      <a href={link.href} class="text-2xl font-light text-primary-900 dark:text-primary-100 hover:opacity-50 transition-opacity text-center">
        {link.name}
      </a>
    ))}
  </div>
</header>