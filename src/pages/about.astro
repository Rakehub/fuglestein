---
import Heading from '../components/about/Heading.astro';
import Mission from '../components/about/Mission.astro';
import Values from '../components/about/Values.astro';
import Layout from '../layouts/Layout.astro';
import Photo from '../components/about/Photo.astro';
---

<Layout
  description="Find more our history, values, mission and more. We are a group of people who share the same values."
  title="About · Stone"
>
  <Heading
  title="Historien vår" 
  subtitle="Dyrka med lidenskap mellom jernalderhistorie og fjordsol." 
/>

  <Mission 
  famTitle="Familien på Fuglestein"
  famDesc1="Me er ein familie som brenn for å føra den stolte arven på Fuglestein vidare. For oss handlar ikkje fruktdyrking berre om produksjon, men om kjærleik til faget, berekraft og det å skapa unike produkt av ypperste kvalitet."
  famDesc2="Gjennom generasjonar har frukthagen vore hjartet på garden vår. Kvar einaste dag legg me ned mykje arbeid og lidenskap i arbeidet, slik at du kan nyta den ekte smaken av Ryfylke – enten du smakar på den friske eplemosten vår eller vår eigenproduserte sider. Velkomen til gards!"
  famImgAlt="Familien på Fuglestein i arbeid"
  
  histTitle="Historia til garden"
  histDesc1="Fuglestein ligg lunt og sørvent, 70 meter over havet nær Ryfylkefjorden. På toppen av morenen her finn ein eit gamalt gravfelt frå jernalderen, med minst seks gravrøyser og to bautasteinar der det er funne både sølvringar og treknivar."
  histDesc2="Men løyndommen bak den frodige voksteren og den unike sødmen i frukta vår ligg i bakken. Jorda vår er rik på fyllitt, ei næringsrik, forsteina leire som gjer jordsmonnet heilt perfekt for fruktdyrking."
  histDesc3="Denne tradisjonen er gamal på garden; den eldste kjende eplehagen her er dokumentert heilt tilbake til 1838. Kombinasjonen av dei varme dagane, dei kjølige haustnettene og den næringsrike jorda er det som gjev frukta vår den heilt særskilde fargen og fyldige smaken du finn i glasset."
/>
  <Values slogan="Frå Ryfylke-fjorden til flaska di — med stoltheit gjennom generasjonar."
  location="Fuglestein Fruktgard · Jelsa, Norge"
  btnPrimary="Oppdag våre produkt"
  btnSecondary="Ta kontakt"
  linkPrimary="/product"
  linkSecondary="/contact"
/>

<Photo title="Glimt frå garden"/>

</Layout>
