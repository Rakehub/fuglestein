---
import Heading from '../components/about/Heading.astro';
import Mission from '../components/about/Mission.astro';
import Values from '../components/about/Values.astro';
import Layout from '../layouts/Layout.astro';
import Photo from '../components/about/Photo.astro';
---

<Layout
  description="Finn ut mer om vår historie, våre verdier, vår misjon og mer. Vi er en gruppe mennesker som deler de samme verdiene."
  title="Om oss · Fuglestein Fruktgard"
>
  <Heading
  title="Historien vår" 
  subtitle="Dyrket med lidenskap mellom jernalderhistorie og fjordsol." 
/>

  <Mission 
  famTitle="Familien på Fuglestein"
  famDesc1="Vi er en familie som brenner for å føre den stolte arven på Fuglestein videre. For oss handler ikke fruktdyrking bare om produksjon, men om kjærlighet til faget, bærekraft og det å skape unike produkter av ypperste kvalitet."
  famDesc2="Gjennom generasjoner har frukthagen vært hjertet på gården vår. Hver eneste dag legger vi ned mye arbeid og lidenskap i arbeidet, slik at du kan nyte den ekte smaken av Ryfylke – enten du smaker på den friske eplemosten vår eller vår egenproduserte sider. Velkommen til gårds!"
  famImgAlt="Familien på Fuglestein i arbeid"
  
  histTitle="Historien til gården"
  histDesc1="Fuglestein ligger lunt og sørvendt, 70 meter over havet nær Ryfylkefjorden. På toppen av morenen her finner en et gammelt gravfelt fra jernalderen, med minst seks gravrøyser og to bautasteiner hvor det er funnet både sølvringer og trekniver."
  histDesc2="Men hemmeligheten bak den frodige veksten og den unike sødmen i frukten vår ligger i bakken. Jorden vår er rik på fyllitt, en næringsrik, forsteinet leire som gjør jordsmonnet helt perfekt for fruktdyrking."
  histDesc3="Denne tradisjonen er gammel på gården; den eldste kjente eplehagen her er dokumentert helt tilbake til 1838. Kombinasjonen av de varme dagene, de kjølige høstnettene og den næringsrike jorden er det som gir frukten vår den helt særskilte fargen og fyldige smaken du finner i glasset."
/>
  <Values slogan="Fra Ryfylke-fjorden til flasken din — med stolthet gjennom generasjoner."
  location="Fuglestein Fruktgard · Jelsa, Norge"
  btnPrimary="Oppdag våre produkter"
  btnSecondary="Ta kontakt"
  linkPrimary="/product"
  linkSecondary="/contact"
/>

<Photo title="Glimt frå garden"/>

</Layout>
