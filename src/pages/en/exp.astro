---
import Cta from '../../components/exp/Cta.astro';
import Faq from '../../components/exp/Faq.astro';
import Heading from '../../components/exp/Heading.astro';
import PricingTable from '../../components/exp/PricingTable.astro';
import Layout from '../../layouts/Layout.astro';

const experiences = [
  { id: 'sider', name: 'Cider Tasting', description: 'Taste our selection with a brief history of the farm.', duration: 'approx. 1 hour' },
  { id: 'omvising', name: 'Orchard Tour', description: 'Walk through the rows of fruit trees with us as your guide.', duration: 'approx. 1.5 hours' },
  { id: 'kombinert', name: 'Combined Experience', description: 'Tour and cider tasting combined in a relaxed morning or afternoon.', duration: 'approx. 2.5 hours' },
];

const faqData = [
  { id: 'faq-1', title: 'Do I need to book a tour in advance?', answer: 'Yes, we appreciate it if you let us know in advance.' },
  { id: 'faq-2', title: 'Can I pay with Vipps?', answer: 'Yes, we accept payment via Vipps.' },
  { id: 'faq-3', title: 'Is the farm shop open every day?', answer: 'Yes, our farm shop is open 24/7.' },
  { id: 'faq-4', title: 'Do you accept large groups?', answer: 'We are happy to welcome groups, please contact us.' },
  { id: 'faq-5', title: 'Where can I park?', answer: 'We have dedicated parking spaces right by the shop.' },
  { id: 'faq-6', title: 'What kind of footwear should I wear?', answer: 'We recommend comfortable shoes suitable for outdoors.' }
];
---

<Layout
  description="Experience our orchard and join us for a tasting."
  title="Fuglestein Fruktgard"
>
  <Heading 
    title="Experience Fuglestein" 
    subtitle="Guided tours in the orchard and tastings of our farm products."
  />

  <PricingTable 
    videoSrc="/assets/visit.webm"
    description="We are happy to welcome groups for an educational journey through our orchard. Contact us to schedule a visit."
  />
   
<Faq 
  title="Plan your visit"
  subtitle="Choose your experience and send us a request. Would you rather see what we make?"
  linkText="Discover our products"
  labelStep="01 · Select experience"
  labelName="Name *"
  labelPhone="Phone (optional)"
  labelPeople="Number of people"
  labelDate="Preferred date"
  buttonText="Send request"
  experiences={experiences} 
/>
  
  <Cta title="Frequently Asked Questions" questions={faqData}/>
</Layout>