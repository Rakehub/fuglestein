---
import PricingTable from '../../components/product/PricingTable.astro';
import Layout from '../../layouts/Layout.astro';

const categories = [
  { label: "All", value: "Alle" },
  { label: "Cider", value: "Sider" },
  { label: "Apple Juice", value: "Eplemost" },
  { label: "Pear Juice", value: "Pærmost" }
];

const catMap = { 
  "Sider": "Cider", 
  "Eplemost": "Apple Juice", 
  "Pærmost": "Pear Juice" 
};

const products = [
  { name: "Katja ", cat: "Eplemost", img: "/assets/products/katja.webp" },
  { name: "Aroma", cat: "Eplemost", img: "/assets/products/aroma.webp" },
  { name: "Freya", cat: "Eplemost", img: "/assets/products/freya.webp" },
  { name: "Pær", cat: "Pærmost", img: "/assets/products/paere.webp" },
  { name: "3 Liter", cat: "Eplemost", img: "/assets/products/box.webp" },
  { name: "Rubinstep", cat: "Eplemost", img: "/assets/products/rubinstep.webp" },
  { name: "Rosette", cat: "Eplemost", img: "/assets/products/rosette.webp" },
  { name: "Morene", cat: "Sider", img: "/assets/products/morene.webp" },
  { name: "Katja", cat: "Sider", img: "/assets/products/katja_sid.webp" },
  { name: "Glimmer", cat: "Sider", img: "/assets/products/glimmer.webp" },
  { name: "8-Skilling", cat: "Sider", img: "/assets/products/8skilling.webp" },
];
---

<Layout
  description="Explore our selection of home-grown cider and apple juice."
  title="Products | Fuglestein Fruktgard"
>
  <PricingTable
    title="Farm Shop" 
    categories={categories} 
    categoryMap={catMap} 
    products={products} 
  />
</Layout>