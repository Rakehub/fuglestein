---
import PricingTable from '../../components/product/PricingTable.astro'; // Ajusta la ruta según donde esté tu archivo
import Layout from '../../layouts/Layout.astro';

// Definimos los datos aquí para que el componente no tenga textos "hardcoded"
const categories = [
  { label: "All", value: "Alle" },
  { label: "Cider", value: "Sider" },
  { label: "Apple Juice", value: "Eplemost" },
  { label: "Pear Juice", value: "Pærmost" }
];

const catMap = { 
  "Sider": "Cider", 
  "Eplemost": "Apple Juice", 
  "Pærmost": "Pear Juice" 
};

const products = [
  { name: "Katja ", cat: "Eplemost", img: "/assets/products/katja.png" },
  { name: "Aroma", cat: "Eplemost", img: "/assets/products/aroma.png" },
  { name: "Freya", cat: "Eplemost", img: "/assets/products/freya.png" },
  { name: "Pær", cat: "Pærmost", img: "/assets/products/paere.png" },
  { name: "3 Liter", cat: "Eplemost", img: "/assets/products/box.png" },
  { name: "Rubinstep", cat: "Eplemost", img: "/assets/products/rubinstep.png" },
  { name: "Rosette", cat: "Eplemost", img: "/assets/products/rosette.png" },
  { name: "Morene", cat: "Sider", img: "/assets/products/morene.png" },
  { name: "Katja", cat: "Sider", img: "/assets/products/katja_sid.png" },
  { name: "Glimmer", cat: "Sider", img: "/assets/products/glimmer.png" },
  { name: "8-Skilling", cat: "Sider", img: "/assets/products/8skilling.png" },
];
---

<Layout
  description="Explore our selection of home-grown cider and apple juice."
  title="Products | Fuglestein Fruktgard"
>
  <PricingTable
    title="Farm Shop" 
    categories={categories} 
    categoryMap={catMap} 
    products={products} 
  />
</Layout>