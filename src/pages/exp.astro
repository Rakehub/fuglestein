---
import Cta from '../components/exp/Cta.astro';
import Faq from '../components/exp/Faq.astro';
import Heading from '../components/exp/Heading.astro';
import PricingTable from '../components/exp/PricingTable.astro';
import Layout from '../layouts/Layout.astro';

const experiences = [
  { id: 'sider', name: 'Sidersmaking', description: 'Smak gjennom utvalet vårt med ei kort historie om garden.', duration: 'ca. 1 time' },
  { id: 'omvising', name: 'Omvising i eplehagen', description: 'Gå gjennom rekkene av frukttre med oss som guide.', duration: 'ca. 1,5 time' },
  { id: 'kombinert', name: 'Kombinert oppleving', description: 'Omvising og sidersmaking samla i ein avslappa formiddag eller ettermiddag.', duration: 'ca. 2,5 time' },
];

const faqData = [
  { id: 'faq-1', title: 'Må eg bestille omvising på førehand?', answer: 'Ja, me set pris på at de melder frå på førehand.' },
  { id: 'faq-2', title: 'Kan ein betale med Vipps?', answer: 'Ja, me tek imot betaling via Vipps.' },
  { id: 'faq-3', title: 'Er gardsutsalet ope kvar dag?', answer: 'Ja, gardsutsalet vårt er ope 24/7.' },
  { id: 'faq-4', title: 'Tek de imot store grupper?', answer: 'Me tek gjerne imot grupper, ta kontakt for opplegg.' },
  { id: 'faq-5', title: 'Kor kan eg parkere?', answer: 'Me har eigne parkeringsplassar rett ved gardsutsalet.' },
  { id: 'faq-6', title: 'Kva slags fottøy bør eg ha på meg?', answer: 'Me tilrår gode sko som toler litt utebruk.' }
];
---


<Layout
  description="Opplev vår frukthage og bli med på smaking."
  title="Fuglestein Fruktgard"
>
  <Heading 
    title="Opplev Fuglestein" 
    subtitle="Omvising i frukthagen og smaking av gardsprodukta våre."
  />

  <PricingTable 
    videoSrc="/assets/visit.webm"
    description="Me tek gjerne imot grupper for ei lærerik reise i frukthagen vår. Ta kontakt for å avtale tidspunkt."
  />
  
  <Faq 
  title="Planlegg besøket ditt"
  subtitle="Vel di oppleving, og send oss ein forespurnad. Vil du heller sjå kva me lagar?"
  linkText="Oppdag våre produkt"
  labelStep="01 · Vel oppleving"
  labelName="Namn *"
  labelPhone="Telefon (valgfritt)"
  labelPeople="Antal personar"
  labelDate="Ønska tidspunkt"
  buttonText="Send forespurnad"
  experiences={experiences} 
/>
  
  <Cta title="Ofte stilte spørsmål" questions={faqData} />
</Layout>