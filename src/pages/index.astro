---
import About from '../components/home/About.astro';
import Cta from '../components/home/Cta.astro';
import Hero from '../components/home/Hero.astro';
import Services from '../components/home/Services.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  description="Fuglestein Fruktgard er en familiegård og håndverkssideri i Ryfylke som produserer premium eplemost og sider."
  title="Fuglestein Fruktgard"
>
  <Hero title="Ekte smaker fra frukthagen på Jelsa"
  description="Vi presser epler, pærer og bær fra egne trær til frisk most, saft og håndverkssider. Velkommen til gårdsutsalg og smaking ved fjorden."
  imageAlt="Oversiktsbilde av frukthagen fra luften"/>

  <Services
  label="GARDSUTSAL"
  title="Vegutsal – Ope heile døgnet"
  description="Det vesle vegutsalet vårt er basert på sjølvbetjening og er ope 24 timer i døgnet, slik at du kan stikke innom når det passar deg for å kjøpe fersk frukt, eplemost og andre lokale produkt."
  note="* Merk: Sal av sider (alkohol) fylgjer gjeldande lovverk og opningstider."
/>

  <About
  title="En del av den lokale reisen" 
  moreText="Les mer på nett" 
  services={[
    {
      name: 'Fjord Norway',
      description: 'Gårdsbutikken vår er vakkert plassert ved fjorden i Suldal. På den offisielle reiselivsportalen for Vestlandet blir vi trukket frem som et flott stoppested for å smake og kjøpe lokal eplemost og sider.',
      image: '/assets/fjord.webp',
      link: 'https://www.fjordnorway.com/en/see-and-do/farm-shop-at-fuglestein-fruktgard-in-suldal',
      alt: 'Fuglestein Fruktgard presentert på den offisielle reiselivssiden Fjord Norway'
    },
    {
      name: 'Visit Norway',
      description: 'Fruktdyrkingen på Fuglestein strekker seg helt tilbake til 1838 i et historisk område i Jelsa. Med 17 000 nye frukttrær produserer vi sider, eplemost og eplegelé, som blir trukket frem på den offisielle reiselivsportalen.',
      image: '/assets/press.webp',
      link: 'https://www.visitnorway.com/listings/farm-shop-at-fuglestein-fruktgard-in-suldal/243969/',
      alt: 'Gårdsbutikken til Fuglestein Fruktgard omtalt på Visit Norway'
    },
    {
      name: 'Visit Suldal',
      description: 'Som en del av "Matskatter fra Suldal" ligger gården vår idyllisk til ved Økstrafjorden. På den lokale turistguiden blir vi trukket frem for gårdsbesøk, omvisning i eplehagen og smaksprøver av lokalproduserte varer.',
      image: '/assets/suldal.webp',
      link: 'https://www.visitsuldal.com/eat-and-stay/fuglestein-fruktgard-fuglestein',
      alt: 'Fuglestein Fruktgard som en del av Matskatter fra Suldal hos Visit Suldal'
    }
  ]}/>
  <Cta title="Planlegg et besøk på gården" 
  description="Ønsker du omvisning for grupper, teambuilding eller en skreddersydd smaking av sider i eplehagen? Ta kontakt med oss, så planlegger vi en unik opplevelse sammen."
  buttonText="Kontakt oss"
  href="/contact"/>
</Layout>
